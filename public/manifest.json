{
  "manifest_version": 3,
  "name": "Page Find Plus",
  "version": "0.1.0",
  "description": "Advanced in-page find features.",
  "icons": {
    "128": "icon128.png"
  },
  "default_locale": "en",
  "permissions": ["storage"],
  "background": {
    "service_worker": "sw.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "matches": ["<all_urls>"],
      "resources": ["treeWebWorker.js"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self';"
  },
  "action": {
    "default_title": "Page Find Plus"
  },
  "options_page": "options/options.html"
}
